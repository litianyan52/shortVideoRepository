                    android:orientation="vertical">

                    <include
                        layout="@layout/item_setting_function"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="17.5dp"
                        app:title="@{`隐私政策`}" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="10.5dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginEnd="9.5dp"
                        android:background="#fff8f8f8" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:onClick="@{()->viewModel.onSettingOfPrivate()}"
                    android:orientation="vertical">

                    <include
                        layout="@layout/item_setting_function"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="17.5dp"
                        app:title="@{`隐私权限设置`}" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="10.5dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginEnd="9.5dp"
                        android:background="#fff8f8f8" />

                </LinearLayout>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:onClick="@{()->viewModel.onCollectOfPersonInfo()}"
                    android:orientation="vertical">

                    <include
                        layout="@layout/item_setting_function"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="17.5dp"
                        app:title="@{`个人信息收集清单`}" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="10.5dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginEnd="9.5dp"
                        android:background="#fff8f8f8" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:onClick="@{()->viewModel.onAboutUs()}"
                    android:orientation="vertical">

                    <include
                        layout="@layout/item_setting_function"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="17.5dp"
                        app:title="@{`关于我们`}" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="5dp"
                        android:layout_marginStart="10.5dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginEnd="9.5dp"
                        android:background="#fff8f8f8" />

                </LinearLayout>



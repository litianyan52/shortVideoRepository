<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="Data"
            type="com.example.video_data.bean.searchVideoBean.ResSearch" />

        <variable
            name="label"
            type="String" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_item_search"
        android:paddingBottom="16sp">

        <ImageView
            android:id="@+id/search_video_cover"
            ImageUri="@{Data.image}"
            android:layout_width="160dp"
            android:layout_height="120dp"
            android:scaleType="centerCrop"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@color/black" />


        <TextView
            android:id="@+id/search_video_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="14dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@{Data.title}"
            android:textColor="#ff000000"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/search_video_cover"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="夏日冲浪日记" />

        <TextView
            android:id="@+id/search_video_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginBottom="15dp"
            android:text="@{label}"
            android:textColor="#ff000000"
            android:textSize="11sp"
            app:layout_constraintBottom_toBottomOf="@id/search_video_cover"
            app:layout_constraintStart_toEndOf="@id/search_video_cover"
            tools:text="# 旅行" />

        <TextView
            android:id="@+id/search_video_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16.5dp"
            android:layout_marginBottom="15dp"
            android:background="@drawable/bg_search_video_duration"
            android:text="12:49"
            android:textColor="#ff444444"
            android:textSize="11sp"
            app:layout_constraintBottom_toBottomOf="@id/search_video_cover"
            app:layout_constraintEnd_toEndOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
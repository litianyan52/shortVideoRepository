<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="viewModel"
            type="com.featuremediaplay.ui.myCollect.MyCollectViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context="com.featuremediaplay.ui.myCollect.MyCollectActivity">

        <ImageView
            android:id="@+id/my_collect_back"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="14dp"
            android:layout_marginTop="2dp"
            android:src="@mipmap/icon_arrow_bl_left"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <TextView
            android:id="@+id/my_collect_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="我的收藏"
            android:textColor="#ff9c9c9c"
            android:textSize="13sp"
            app:layout_constraintBottom_toBottomOf="@id/my_collect_back"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/my_collect_back" />

<!--        <TextView-->
<!--            android:id="@+id/my_collect_edit"-->
<!--            android:layout_width="wrap_content"-->
<!--            android:layout_height="wrap_content"-->
<!--            android:layout_marginEnd="14dp"-->
<!--            android:text="编辑"-->
<!--            android:textColor="#ff000000"-->
<!--            android:textSize="13sp"-->
<!--            app:layout_constraintBottom_toBottomOf="@id/my_collect_title"-->
<!--            app:layout_constraintEnd_toEndOf="parent"-->
<!--            app:layout_constraintTop_toTopOf="@id/my_collect_title" />-->

        <View
            android:id="@+id/my_collect_line"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="13.5dp"
            android:background="#1a000000"
            app:layout_constraintTop_toBottomOf="@id/my_collect_title" />/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/my_collect_recyclerview"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/my_collect_line" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
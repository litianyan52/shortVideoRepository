<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tool="http://schemas.android.com/tools">

    <data>

        <variable
            name="viewModel"
            type="com.featurefind.fragment.FindViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FBFBFB">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_constraintStart_toStartOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/first_cs"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/find_search"
                    android:layout_width="300dp"
                    android:layout_height="32dp"
                    android:layout_marginLeft="14dp"
                    android:background="@drawable/bg_find_search"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:text="搜索视频，作者，用户及标签"
                    android:textColor="#808080"
                    android:textSize="11sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:id="@+id/find_notify"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="14dp"
                    android:src="@mipmap/icon_notify"
                    app:layout_constraintBottom_toBottomOf="@id/find_search"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/find_label_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="14dp"
                    android:layout_marginTop="20dp"
                    android:text="分类"
                    android:textColor="#ff000000"
                    android:textSize="16sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/find_search" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerview_category"
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    android:layout_marginLeft="14dp"
                    android:layout_marginTop="20dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/find_label_category" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/white"
                    android:paddingBottom="18dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/recyclerview_category">


                    <TextView
                        android:id="@+id/find_label_theme"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="14dp"
                        android:layout_marginTop="18dp"
                        android:text="主题播单"
                        android:textColor="#ff000000"
                        android:textSize="16sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:id="@+id/find_arrow_of_theme"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="14dp"
                        android:src="@mipmap/icon_arrow"
                        app:layout_constraintBottom_toBottomOf="@id/find_label_theme"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/find_label_theme" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerview_theme"
                        android:layout_width="match_parent"
                        android:layout_height="178dp"
                        android:layout_marginLeft="14dp"
                        android:layout_marginTop="16dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/find_label_theme" />

                    <TextView
                        android:id="@+id/find_label_topic_pia"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="14dp"
                        android:layout_marginTop="22dp"
                        android:text="话题广场"
                        android:textColor="#ff000000"
                        android:textSize="16sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/recyclerview_theme" />

                    <ImageView
                        android:id="@+id/find_arrow_of_topic_pia"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="14dp"
                        android:src="@mipmap/icon_arrow"
                        app:layout_constraintBottom_toBottomOf="@id/find_label_topic_pia"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/find_label_topic_pia" />

                    <ImageView
                        android:id="@+id/third_image"
                        ImageUri="@{viewModel.topicDataList.get(2).image}"
                        android:layout_width="267dp"
                        android:layout_height="141dp"
                        android:layout_marginEnd="14dp"
                        android:scaleType="centerCrop"
                        app:layout_constraintBottom_toBottomOf="@id/second_image"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/second_image"
                        tool:background="#f111" />

                    <ImageView
                        android:id="@+id/second_image"
                        ImageUri="@{viewModel.topicDataList.get(1).image}"
                        android:layout_width="297dp"
                        android:layout_height="157dp"
                        android:layout_marginEnd="22dp"
                        android:scaleType="centerCrop"
                        app:layout_constraintBottom_toBottomOf="@id/first_image"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/first_image"
                        tool:background="#f422" />

                    <ImageView
                        android:id="@+id/first_image"
                        ImageUri="@{viewModel.topicDataList.get(0).image}"
                        android:layout_width="330dp"
                        android:layout_height="175dp"
                        android:layout_marginLeft="14dp"
                        android:layout_marginTop="20dp"
                        android:scaleType="centerCrop"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/find_label_topic_pia"
                        tool:background="#f454" />


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="12dp"
                        android:text="@{viewModel.topicDataList.get(0).title}"
                        android:textColor="#ffffffff"
                        android:textSize="14sp"
                        app:layout_constraintStart_toStartOf="@id/first_image"
                        app:layout_constraintTop_toTopOf="@id/first_image"
                        tool:text="冬日旅行收藏夹" />


                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>


        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>